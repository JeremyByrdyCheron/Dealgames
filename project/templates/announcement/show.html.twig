{% extends 'base.html.twig' %}

{% block title %}{% endblock %}

{% block body %}
	<a href=" {{ path('create-announcement') }} ">Créer une annonce</a>


	<div href="{{ path('announcement.show', {id:announcement.id}) }}" class="announcement-card">


		<h2>{{ announcement.title }}</h2>

		<p>
			<strong>Catégorie :</strong>
			{{ announcement.category ? announcement.category.name : 'Non définie' }}</p>

		<p>
			<strong>Date :</strong>
			{{ announcement.date ? announcement.date|date('d/m/Y H:i') : 'Non définie' }}</p>

		<p>{{ announcement.description }}</p>

		{% if announcement.imageName %}
			<div>
				<img src="{{ asset('images/announcements/' ~ announcement.imageName) }}" alt="Image de {{ announcement.title }}">
			</div>
		{% endif %}
		{% if isAuthor===true %}

			<a href="{{ path('announcement.edit', {id: announcement.id}) }}">Éditer</a>
			<form method="POST" action="{{path('announcement.delete', {id: announcement.id})}}" onsubmit="return confirm ('tu es sûr ?');">
				<button type="submit">Supprimer</button>
			</form>
		{% endif %}


	</div>


{% endblock %}
