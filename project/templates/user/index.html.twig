{% extends 'base.html.twig' %}

{% block title %}Profil
{% endblock %}

{% block body %}
	<div>
		<h1>
			{{user.firstname}}
			{{user.lastname}}
		</h1>

		<p>
			{{user.email}}
		</p>
		<p>
			<a href="{{ path('forgotten_password') }}">Réinitialiser le mot de passe</a>
		</p>
		<p>
			<a href="{{ path('app_logout') }}">Se déconnecter</a>
		</p>
		<h2>
			Vos annonces
		</h2>
		{% for announcement in announcements %}
			<a href="{{ path('announcement.show', {id:announcement.id}) }}" class="announcement-card">

				<h2>{{ announcement.title }}</h2>

				<p>
					<strong>Catégorie :</strong>
					{{ announcement.category ? announcement.category.name : 'Non définie' }}</p>

				<p>
					<strong>Date :</strong>
					{{ announcement.date ? announcement.date|date('d/m/Y H:i') : 'Non définie' }}</p>

				<p>{{ announcement.description }}</p>

				{% if announcement.imageName %}
					<div>
						<img src="{{ asset('images/announcements/' ~ announcement.imageName) }}" alt="Image de {{ announcement.title }}">
					</div>
				{% endif %}
			</a>
		{% endfor %}
		<h2>
			Les annonces qui vous intéressent
		</h2>
		{% for announcement in interestedAnnouncements %}
			<a href="{{ path('announcement.show', {id:announcement.id}) }}" class="announcement-card">

				<h2>{{ announcement.title }}</h2>

				<p>
					<strong>Catégorie :</strong>
					{{ announcement.category ? announcement.category.name : 'Non définie' }}</p>

				<p>
					<strong>Date :</strong>
					{{ announcement.date ? announcement.date|date('d/m/Y H:i') : 'Non définie' }}</p>

				<p>{{ announcement.description }}</p>

				{% if announcement.imageName %}
					<div>
						<img src="{{ asset('images/announcements/' ~ announcement.imageName) }}" alt="Image de {{ announcement.title }}">
					</div>
				{% endif %}
			</a>
		{% endfor %}
	</div>
{% endblock %}
